# Verxio API control-plane URL for local dev and Docker parity mode.
VITE_VERXIO_API_ENABLED=true
VITE_VERXIO_API_URL=http://127.0.0.1:8787

# Optional direct Hermes dashboard mode for debugging the upstream UI bridge.
# Set this only when bypassing Verxio API.
# HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# Optional: path to Hermes clone when documenting local setup.
VERXIO_HERMES_REPO=../hermes-agent
