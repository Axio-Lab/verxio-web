{
  "name": "verxio-web",
  "private": true,
  "version": "0.1.0",
  "description": "Verxio web UI — browser shell over the Hermes Agent runtime.",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5180",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4180",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test:ui": "vitest run --environment jsdom"
  },
  "dependencies": {
    "@hermes/shared": "file:../hermes-agent/apps/shared",
    "@nous-research/ui": "^0.13.0",
    "@tanstack/react-query": "^5.100.6",
    "clsx": "^2.1.1",
    "nanostores": "^1.3.0",
    "@nanostores/react": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "jsdom": "^29.1.1"
  }
}
