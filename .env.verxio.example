# Required for production parity mode.
VERXIO_DATABASE_MODE=turso
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Local Docker runtime image built from ./hermes-agent.
VERXIO_HERMES_IMAGE=verxio-hermes-runtime:local
HERMES_UID=10000
HERMES_GID=10000

# Local-only. The API container uses /app/.verxio; host Docker needs the host path.
VERXIO_RUNTIME_DOCKER_ROOT=/absolute/path/to/verxio-ai/.verxio/runtimes
VERXIO_RUNTIME_CONNECT_HOST=host.docker.internal
VERXIO_RUNTIME_PUBLISH_HOST=127.0.0.1

# Use true only behind HTTPS.
VERXIO_COOKIE_SECURE=false
VERXIO_CORS_ORIGINS=https://your-verxio-web.example

# Auth code security and email delivery.
# Set VERXIO_AUTH_CODE_SECRET to a long random value in production.
VERXIO_AUTH_CODE_SECRET=change-this-long-random-secret
VERXIO_AUTH_CODE_TTL_MINUTES=10
VERXIO_AUTH_CODE_MAX_ATTEMPTS=5
VERXIO_SMTP_HOST=smtp.example.com
VERXIO_SMTP_PORT=587
VERXIO_SMTP_USERNAME=your-smtp-username
VERXIO_SMTP_PASSWORD=your-smtp-password
VERXIO_SMTP_FROM=Verxio <no-reply@example.com>
VERXIO_SMTP_TLS=true

# Enables the full Composio toolkits catalog and per-tool previews.
COMPOSIO_API_KEY=your-composio-api-key
COMPOSIO_API_BASE_URL=https://backend.composio.dev/api/v3
COMPOSIO_TOOLS_API_BASE_URL=https://backend.composio.dev/api/v3.1
